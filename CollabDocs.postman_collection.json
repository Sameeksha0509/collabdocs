{
  "info": {
    "name": "CollabDocs API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "access_token", "value": "" },
    { "key": "workspace_id", "value": "" },
    { "key": "document_id", "value": "" },
    { "key": "user_id", "value": "" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"pass1234\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"phone\": \"1234567890\"\n}" },
            "url": "{{base_url}}/users/"
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/users/{{user_id}}/"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"pass1234\"\n}" },
            "url": "{{base_url}}/users/login/"
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Team Alpha\"\n}" },
            "url": "{{base_url}}/workspaces/"
          }
        },
        {
          "name": "Get Workspace",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/workspaces/{{workspace_id}}/"
          }
        },
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/workspaces/{{workspace_id}}/members/"
          }
        },
        {
          "name": "Add Member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"teammate@test.com\",\n  \"role\": \"editor\"\n}" },
            "url": "{{base_url}}/workspaces/{{workspace_id}}/members/"
          }
        },
        {
          "name": "Workspace Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/workspaces/{{workspace_id}}/summary/"
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Create Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"workspace\": \"{{workspace_id}}\",\n  \"title\": \"Design Doc\",\n  \"content\": \"Initial content\",\n  \"status\": \"draft\"\n}" },
            "url": "{{base_url}}/documents/"
          }
        },
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/documents/?workspace={{workspace_id}}&status=draft"
          }
        },
        {
          "name": "Update Document",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Design Doc\",\n  \"content\": \"Updated content v2\",\n  \"status\": \"published\"\n}" },
            "url": "{{base_url}}/documents/{{document_id}}/"
          }
        },
        {
          "name": "Get Versions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/documents/{{document_id}}/versions/"
          }
        },
        {
          "name": "Document Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/documents/{{document_id}}/stats/"
          }
        },
        {
          "name": "Add Tags",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"tags\": [\"urgent\", \"important\"]\n}" },
            "url": "{{base_url}}/documents/{{document_id}}/tags/"
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"document\": \"{{document_id}}\",\n  \"content\": \"This looks good!\"\n}" },
            "url": "{{base_url}}/comments/"
          }
        },
        {
          "name": "Create Reply",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"document\": \"{{document_id}}\",\n  \"content\": \"I agree\",\n  \"parent\": \"<comment_id>\"\n}" },
            "url": "{{base_url}}/comments/"
          }
        },
        {
          "name": "Get Comments by Document",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/comments/?document={{document_id}}"
          }
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "Create Tag",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"urgent\"\n}" },
            "url": "{{base_url}}/tags/"
          }
        },
        {
          "name": "List Tags",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/tags/"
          }
        }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/audit-logs/"
          }
        },
        {
          "name": "Filter by Actor",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/audit-logs/?actor={{user_id}}"
          }
        },
        {
          "name": "Filter by Date Range",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/audit-logs/?date_from=2024-01-01&date_to=2024-12-31"
          }
        }
      ]
    }
  ]
}
